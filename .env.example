# Copy to `.env.local` and fill in values (never commit `.env.local`).

# --- Supabase (browser + server) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- GoHighLevel ---
GHL_API_KEY=
GHL_LOCATION_ID=

# --- Clover (sandbox or production) ---
CLOVER_MERCHANT_ID=
CLOVER_API_ACCESS_KEY=
CLOVER_ACCESS_TOKEN=
CLOVER_APP_SECRET=

# --- Optional local dev: proxy /api/* from Vite to your deployed Vercel app ---
# Lets `npm run dev` call real serverless routes without `vercel dev`.
# Example: https://homereadyscores.com
# VITE_API_PROXY=
